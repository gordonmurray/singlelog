data_dir = "/var/lib/vector"

[api]
enabled = true

[sources.nginx]
type = "file"
include = ["/var/log/nginx/access.log"]
read_from = "beginning"

[transforms.parsed_nginx]
type = "remap"
inputs = ["nginx"]
source = '''
parsed, err = parse_nginx_log(.message, "combined")
if is_null(err) {
  . = merge(., parsed)
}
'''

[sinks.tigris]
type = "aws_s3"
inputs = ["parsed_nginx"]
bucket = "your-tigris-bucket"
endpoint = "https://t3.storage.dev"
region = "auto"
key_prefix = "nginx/"
compression = "none"
batch.timeout_secs = 60

[sinks.tigris.encoding]
codec = "json"
